{
  "name": "@webamoki/web-svelte",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Webamoki/Web-svelte.git"
  },
  "scripts": {
    "dev": "vite dev",
    "build:site": "vite build",
    "build:lib": "pnpm prepack",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "check": "pnpm fmt && pnpm lint:es --fix && pnpm lint:svelte && pnpm test",
    "fmt": "prettier --write --cache --cache-location=.cache/.prettier-cache --cache-strategy metadata --log-level warn .",
    "lint": "pnpm lint:es && pnpm lint:svelte",
    "lint:es": "eslint --cache --cache-location .cache/.eslintcache --cache-strategy metadata .",
    "lint:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test:unit": "vitest run",
    "test": "pnpm test:unit",
    "watch": "svelte-package --watch"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "exports": {
    "./components/form": {
      "types": "./dist/shared/components/form/index.d.ts",
      "svelte": "./dist/shared/components/form/index.js"
    },
    "./components/ui": {
      "types": "./dist/shared/components/ui/index.d.ts",
      "svelte": "./dist/shared/components/ui/index.js"
    },
    "./utils/datetime": {
      "types": "./dist/shared/utils/datetime/index.d.ts",
      "import": "./dist/shared/utils/datetime/index.js",
      "require": "./dist/shared/utils/datetime/index.js"
    },
    "./utils/zod": {
      "types": "./dist/shared/utils/zod.d.ts",
      "import": "./dist/shared/utils/zod.js",
      "require": "./dist/shared/utils/zod.js"
    },
    "./utils/form": {
      "types": "./dist/shared/utils/form/index.d.ts",
      "import": "./dist/shared/utils/form/index.js",
      "require": "./dist/shared/utils/form/index.js"
    },
    "./utils/email": {
      "types": "./dist/shared/utils/email/index.d.ts",
      "import": "./dist/shared/utils/email/index.js",
      "require": "./dist/shared/utils/email/index.js"
    },
    "./utils/functional": {
      "types": "./dist/shared/utils/functional/index.d.ts",
      "import": "./dist/shared/utils/functional/index.js",
      "require": "./dist/shared/utils/functional/index.js"
    },
    "./utils/env": {
      "types": "./dist/shared/utils/env.d.ts",
      "import": "./dist/shared/utils/env.js",
      "require": "./dist/shared/utils/env.js"
    },
    "./server/env": {
      "types": "./dist/shared/server/env.d.ts",
      "import": "./dist/shared/server/env.js",
      "require": "./dist/shared/server/env.js"
    },
    "./server/form-handler": {
      "types": "./dist/shared/server/form-handler.d.ts",
      "import": "./dist/shared/server/form-handler.js",
      "require": "./dist/shared/server/form-handler.js"
    },
    "./server/form-processor": {
      "types": "./dist/shared/server/form-processor.d.ts",
      "import": "./dist/shared/server/form-processor.js",
      "require": "./dist/shared/server/form-processor.js"
    },
    "./utils/remote": {
      "types": "./dist/shared/utils/remote.d.ts",
      "import": "./dist/shared/utils/remote.js",
      "require": "./dist/shared/utils/remote.js"
    },
    "./utils/command": {
      "types": "./dist/shared/utils/command.svelte.d.ts",
      "svelte": "./dist/shared/utils/command.svelte.js",
      "import": "./dist/shared/utils/command.svelte.js",
      "require": "./dist/shared/utils/command.svelte.js"
    }
  },
  "peerDependencies": {
    "@internationalized/date": "catalog:",
    "@sveltejs/kit": "catalog:",
    "@tailwindcss/forms": "catalog:",
    "@tailwindcss/typography": "catalog:",
    "svelte": "catalog:",
    "sveltekit-superforms": "catalog:",
    "tailwindcss": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@anolilab/semantic-release-pnpm": "^8.1.1",
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^9.39.4",
    "@fontsource-variable/inter": "^5.2.8",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.14.0",
    "@standard-schema/spec": "^1.1.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "catalog:",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/forms": "catalog:",
    "@tailwindcss/typography": "catalog:",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/ramda": "^0.31.1",
    "@types/sorted-array-functions": "^1.3.3",
    "clsx": "^2.1.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "publint": "^0.3.18",
    "semantic-release": "^25.0.3",
    "shadcn-svelte": "^1.2.7",
    "shiki": "^4.0.2",
    "svelte": "catalog:",
    "svelte-check": "^4.4.6",
    "svelte-eslint-parser": "^1.6.0",
    "sveltekit-superforms": "catalog:",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "catalog:",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "zod": "catalog:"
  },
  "keywords": [
    "svelte"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "workerd"
    ]
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "bits-ui": "^2.17.3",
    "devalue": "^5.7.1",
    "formsnap": "^2.0.1",
    "ramda": "^0.32.0",
    "sorted-array-functions": "^1.3.0",
    "svelte-awesome-color-picker": "^4.1.2",
    "svelte-sonner": "^1.1.0"
  },
  "engines": {
    "node": "^24.0.0",
    "pnpm": "^10.0.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
